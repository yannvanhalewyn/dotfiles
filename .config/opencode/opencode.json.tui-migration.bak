{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opus 4.6",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
  },
  "plugin": [
    "opencode-anthropic-auth"
  ],
  "keybinds": {
    "input_submit": "return",
    "input_newline": "shift+return"
  },
}
